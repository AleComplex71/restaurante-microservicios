<?xml version="1.0" encoding="UTF-8"?>
<configuration debug="false">
    <!-- Obtener el nombre del servicio desde application.properties -->
    <springProperty scope="context" name="APP_NAME" source="spring.application.name"/>
    <springProperty scope="context" name="LOG_FILE" source="logging.file.name" defaultValue="logs/${APP_NAME}"/>

    <!-- Patrón de log en texto plano (opcional) -->
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n"/>

    <!-- ===== APPENDER CONSOLA EN JSON ===== -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"${APP_NAME}","environment":"development"}</customFields>
            <includeContext>true</includeContext>
            <includeMdc>true</includeMdc>
            <writeVersion>true</writeVersion>
        </encoder>
    </appender>

    <!-- ===== APPENDER ARCHIVO EN JSON CON ROTACIÓN ===== -->
    <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}.json</file>

        <!-- Política de rotación: Diaria + límite de archivo -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.%i.json</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>

        <!-- Encoder JSON -->
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"${APP_NAME}","environment":"development"}</customFields>
            <includeContext>true</includeContext>
            <includeMdc>true</includeMdc>
            <writeVersion>true</writeVersion>
        </encoder>
    </appender>

    <!-- ===== APPENDER CONSOLA EN TEXTO PLANO (Desarrollo) ===== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ===== LOGGERS ESPECÍFICOS ===== -->
    <!-- Spring Framework -->
    <logger name="org.springframework" level="INFO"/>
    <logger name="org.springframework.boot" level="INFO"/>
    <logger name="org.springframework.cloud" level="DEBUG"/>
    <logger name="org.springframework.web" level="INFO"/>

    <!-- Hibernate -->
    <logger name="org.hibernate" level="WARN"/>
    <logger name="org.hibernate.SQL" level="DEBUG"/>

    <!-- Application loggers -->
    <logger name="com.restaurante" level="DEBUG"/>

    <!-- ===== ROOT LOGGER ===== -->
    <root level="INFO">
        <!-- Comentar uno de estos según necesites -->
        <appender-ref ref="JSON_CONSOLE"/>  <!-- Logs JSON en consola -->
        <appender-ref ref="JSON_FILE"/>     <!-- Logs JSON en archivo -->
        <!-- <appender-ref ref="CONSOLE"/> -->  <!-- Descomenta para logs en texto plano -->
    </root>

    <!-- ===== PERFILES DE SPRING ===== -->
    <!-- Perfil: development (logs más verbosos) -->
    <springProfile name="development">
        <logger name="com.restaurante" level="DEBUG"/>
        <logger name="org.springframework.web" level="DEBUG"/>
    </springProfile>

    <!-- Perfil: production (logs menos verbosos) -->
    <springProfile name="production">
        <logger name="com.restaurante" level="INFO"/>
        <root level="WARN">
            <appender-ref ref="JSON_FILE"/>
        </root>
    </springProfile>

</configuration>

